{
	"name": "KTree Runner",
	"build": {
		"dockerfile": "Dockerfile"
	},
	"customizations": {
		"vscode": {
			"settings": {
				"python.defaultInterpreterPath": "/usr/bin/python3"
			},
			"extensions": [
				"ms-python.python",
				"ms-vscode.cpptools",
				"ms-vscode.cmake-tools"
			]
		}
	},
	"postCreateCommand": "python3 -m pip install --user --upgrade pip",
	"remoteUser": "vscode"
}